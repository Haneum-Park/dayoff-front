    "deploy-patch": "clear;printf \"\n\n\n\";npm version patch --no-git-tag-version;printf \"\n\n\n 푸시하시고, 머지요청하셔야 패치됩니다.\n\n\n\n\n\n\n\n\n\n\n\n\n\";printf \"https://github.com/DayOffxyz/dayoff-front/compare\n\n\";git add package.json && git commit && git push",
    "deploy-minor": "clear;printf \"\n\n\n\";npm version minor --no-git-tag-version;printf \"\n\n\n 푸시하시고, 머지요청하셔야 패치됩니다.\n\n\n\n\n\n\n\n\n\n\n\n\n\";printf \"https://github.com/DayOffxyz/dayoff-front/compare\n\n\";git add package.json && git commit && git push",
    "deploy-major": "clear;printf \"\n\n\n\";npm version major --no-git-tag-version;printf \"\n\n\n 푸시하시고, 머지요청하셔야 패치됩니다.\n\n\n\n\n\n\n\n\n\n\n\n\n\";printf \"https://github.com/DayOffxyz/dayoff-front/compare\n\n\";git add package.json && git commit && git push"
  },
